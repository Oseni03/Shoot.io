{
	"$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
	"files": {
		"ignoreUnknown": true,
		"includes": ["**", "!node_modules", "!dist"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 4
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	}
}
